# Root env for Docker Compose (copy to `.env` and adjust).
# Dev Compose builds DATABASE_URL from these Postgres settings.

POSTGRES_USER=manifest
POSTGRES_PASSWORD=manifest
POSTGRES_DB=manifest

# Optional for docker-compose.yml: overrides insecure dev defaults if set
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# Optional for docker-compose.prod.yml: set when not using bundled Postgres
# DATABASE_URL=postgresql://user:pass@your-host:5432/yourdb

# Entra (optional)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
