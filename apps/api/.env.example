DATABASE_URL=postgresql://user:password@localhost:5432/manifest
JWT_SECRET=your-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SSO: both tenant + client ID must be non-empty. Secret optional for SPA ID-token flow.
# This file is loaded by the API (cwd apps/api). Restart the API after changes.
# Login UI calls GET /api/auth/sso/config — ensure VITE_API_URL points at this API.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# AI assistant — encrypt stored API keys at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. Dev falls back to an insecure all-zero key with a warning.
ENCRYPTION_KEY=

# Optional — defaults shown
# API_HOST=0.0.0.0
# API_PORT=3001
# SPA origin for CORS. Refresh cookies use Secure only when this starts with https:
# WEB_ORIGIN=http://localhost:5173
